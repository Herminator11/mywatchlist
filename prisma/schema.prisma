model MovieEntity {
  id            Int      @id
  title         String
  date          String   
  posterPath    String?
  mediaType     String 
  listType      String   
  seasonNumber  String   
  finishedDate  String? 
  favoriteCategory String?
  isFavorite     Boolean  @default(false)
  notes         String?
  sortOrder     Int      @default(2147483647) // Int.MAX_VALUE

  @@unique([id, listType, seasonNumber])

  @@index([listType])
  @@index([listType, mediaType])
  @@index([listType, sortOrder])
}

model Settings {
  id          Int     @id @default(autoincrement())
  userId      String  @unique
  autoHideNavBar Boolean @default(false)
  theme       String  @default("system")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}